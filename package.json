{
  "name": "assistente-vozzu",
  "version": "1.0.0",
  "description": "Assistente local para impressão térmica do Vozzu",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "icons": "node scripts/gen-icons.js",
    "start": "tsc && electron .",
    "dist": "node scripts/gen-icons.js && tsc && electron-builder --win --x64"
  },
  "dependencies": {
    "node-thermal-printer": "^4.4.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "electron": "^35.1.0",
    "electron-builder": "^26.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "com.vozzu.assistente",
    "productName": "Assistente Vozzu",
    "directories": {
      "output": "dist-installer"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": false,
      "runAfterFinish": true
    },
    "files": [
      "dist/**/*",
      "build/tray.png",
      "package.json"
    ]
  }
}
